TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Alchemy ───────────────────────────────────────────────────────────────────
# Add as many accounts as you want — no code changes needed.
# Both https:// and wss:// are accepted, auto-converted as needed.
#
# Naming rules:
#   HTTP keys → ALCHEMY_API_KEY, ALCHEMY_API_KEY_2, ALCHEMY_API_KEY_3, ...
#   WS  keys  → ALCHEMY_WS_URL,  ALCHEMY_WS_URL_2,  ALCHEMY_WS_URL_3,  ...
#
# WS keys are optional — if not set, derived from the matching HTTP key.
# Each account = 30M CU/month free tier.

ALCHEMY_API_KEY=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_1
ALCHEMY_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_1

ALCHEMY_API_KEY_2=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_2
ALCHEMY_WS_URL_2=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_2

ALCHEMY_API_KEY_3=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_3
ALCHEMY_WS_URL_3=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_3

# Add more: ALCHEMY_API_KEY_4 + ALCHEMY_WS_URL_4, _5, _6 ... (unlimited)

# ── Etherscan API Keys (1 required, up to 5 supported) ───────────────────────
# Each key = +5 calls/sec capacity for token metadata fetching
# Tip — safe MAX_WORKERS: 1 key=4, 2=9, 3=14, 4=18, 5=22
ETHERSCAN_API_KEY_1=your_first_key_here
ETHERSCAN_API_KEY_2=
ETHERSCAN_API_KEY_3=
ETHERSCAN_API_KEY_4=
ETHERSCAN_API_KEY_5=

# ── Scanning ──────────────────────────────────────────────────────────────────
SCAN_INTERVAL_MINUTES=30

# ── Revival detection (change these anytime) ──────────────────────────────────
REVIVAL_GAP_DAYS=3
MIN_LIQUIDITY_USD=500

# ── Alert behaviour ───────────────────────────────────────────────────────────
ALERT_COOLDOWN_DAYS=7

# ── Performance ───────────────────────────────────────────────────────────────
MAX_WORKERS=4

# ── Dashboard ─────────────────────────────────────────────────────────────────
WEB_PORT=8001
