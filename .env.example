TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Alchemy ───────────────────────────────────────────────────────────────────
# Paste https:// OR wss:// — both formats are accepted, auto-converted as needed
#
# HTTP keys (round-robin for all on-chain calls, each = 30M CU/month free)
ALCHEMY_API_KEY=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_1
ALCHEMY_API_KEY_2=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_2
ALCHEMY_API_KEY_3=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_3
ALCHEMY_API_KEY_4=
ALCHEMY_API_KEY_5=

# Dedicated WebSocket account (use a SEPARATE Alchemy account — 4th key)
# WebSocket events consume CUs independently from HTTP calls.
# If not set, WebSocket shares the primary HTTP account.
ALCHEMY_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_4

# ── Etherscan API Keys (1 required, up to 5 supported) ───────────────────────
# Each key = +5 calls/sec capacity for token metadata fetching
# Tip — safe MAX_WORKERS: 1 key=4, 2=9, 3=14, 4=18, 5=22
ETHERSCAN_API_KEY_1=your_first_key_here
ETHERSCAN_API_KEY_2=
ETHERSCAN_API_KEY_3=
ETHERSCAN_API_KEY_4=
ETHERSCAN_API_KEY_5=

# ── Scanning ──────────────────────────────────────────────────────────────────
SCAN_INTERVAL_MINUTES=30

# ── Revival detection (change these anytime) ──────────────────────────────────
REVIVAL_GAP_DAYS=3
MIN_LIQUIDITY_USD=500

# ── Alert behaviour ───────────────────────────────────────────────────────────
ALERT_COOLDOWN_DAYS=7

# ── Performance ───────────────────────────────────────────────────────────────
MAX_WORKERS=4

# ── Dashboard ─────────────────────────────────────────────────────────────────
WEB_PORT=8001
