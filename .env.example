TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Alchemy (paste the HTTP URL from your Alchemy dashboard) ─────────────────
# WebSocket URL is auto-derived: https:// → wss://
ALCHEMY_API_KEY=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE

# ── Etherscan API Keys (1 required, up to 5 supported) ───────────────────────
# Each key = +5 calls/sec capacity for token metadata fetching
# Tip — safe MAX_WORKERS: 1 key=4, 2=9, 3=14, 4=18, 5=22
ETHERSCAN_API_KEY_1=your_first_key_here
ETHERSCAN_API_KEY_2=
ETHERSCAN_API_KEY_3=
ETHERSCAN_API_KEY_4=
ETHERSCAN_API_KEY_5=

# ── Scanning ──────────────────────────────────────────────────────────────────
SCAN_INTERVAL_MINUTES=30

# ── Revival detection (change these anytime) ──────────────────────────────────
REVIVAL_GAP_DAYS=3
MIN_LIQUIDITY_USD=500

# ── Alert behaviour ───────────────────────────────────────────────────────────
ALERT_COOLDOWN_DAYS=7

# ── Performance ───────────────────────────────────────────────────────────────
MAX_WORKERS=4

# ── Dashboard ─────────────────────────────────────────────────────────────────
WEB_PORT=8000
